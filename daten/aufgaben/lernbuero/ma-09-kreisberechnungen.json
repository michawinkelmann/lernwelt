{
  "thema": "ma-09-kreisberechnungen",
  "hinweis": "Lernbüro-Ergänzungsaufgaben — zur fachlichen Prüfung (ergänzung:lernbüro). IDs ma-09-kb-101 ff.",
  "aufgaben": [
    {
      "id": "ma-09-kb-101",
