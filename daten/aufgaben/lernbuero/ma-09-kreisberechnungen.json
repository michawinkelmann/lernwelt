      "zweig": ["gym", "rs"],
      "niveau": 1,
      "afb": 1,
      "ergaenzung": "lernbuero",
      "frage": "Berechne den Umfang eines Kreises mit Radius $r = 5\\,\\text{cm}$. Runde auf eine Dezimalstelle. (Antwort in cm.)",
      "eingaben": [
        { "label": "Umfang in cm", "antwort": 31.4, "toleranz": 0.1 }
      ],
      "tipps": [
        "Formel: $u = 2 \\cdot \\pi \\cdot r$.",
        "$u = 2 \\cdot \\pi \\cdot 5 = 10\\pi$.",
        "$10\\pi \\approx 31{,}4\\,\\text{cm}$."
      ],
      "loesungsweg": "$u = 2\\pi r = 2 \\cdot \\pi \\cdot 5 = 10\\pi \\approx 31{,}4\\,\\text{cm}$.",
      "kc": ["Raum und Form: Kreisumfang"]
    },
    {
      "id": "ma-09-kb-102",
      "typ": "numerisch",
      "zweig": ["gym", "rs"],
      "niveau": 1,
      "afb": 1,
      "ergaenzung": "lernbuero",
      "frage": "Berechne die Kreisfläche für $r = 4\\,\\text{cm}$. Runde auf eine Dezimalstelle. (Antwort in cm².)",
      "eingaben": [
        { "label": "Fläche in cm²", "antwort": 50.3, "toleranz": 0.1 }
      ],
      "tipps": [
        "Formel: $A = \\pi \\cdot r^2$.",
        "$A = \\pi \\cdot 4^2 = 16\\pi$.",
        "$16\\pi \\approx 50{,}3\\,\\text{cm}^2$."
      ],
      "loesungsweg": "$A = \\pi r^2 = \\pi \\cdot 16 = 16\\pi \\approx 50{,}3\\,\\text{cm}^2$.",
      "kc": ["Raum und Form: Kreisfläche"]
    },
    {
      "id": "ma-09-kb-103",
      "typ": "numerisch",
      "zweig": ["gym", "rs"],
      "niveau": 2,
      "afb": 2,
      "ergaenzung": "lernbuero",
      "frage": "Ein Kreis hat den Umfang $u = 40\\,\\text{cm}$. Berechne den Radius. Runde auf zwei Dezimalstellen. (Antwort in cm.)",
      "eingaben": [
        { "label": "Radius in cm", "antwort": 6.37, "toleranz": 0.02 }
      ],
      "tipps": [
        "Stelle $u = 2\\pi r$ nach $r$ um.",
        "$r = \\frac{u}{2\\pi}$.",
        "$r = \\frac{40}{2\\pi} = \\frac{20}{\\pi} \\approx 6{,}37\\,\\text{cm}$."
      ],
      "loesungsweg": "$u = 2\\pi r \\Rightarrow r = \\frac{u}{2\\pi} = \\frac{40}{2\\pi} = \\frac{20}{\\pi} \\approx 6{,}37\\,\\text{cm}$.",
      "kc": ["Raum und Form: Kreisumfang rückwärts"]
    },
    {
      "id": "ma-09-kb-104",
      "typ": "numerisch",
      "zweig": ["gym", "rs"],
      "niveau": 2,
      "afb": 2,
      "ergaenzung": "lernbuero",
      "frage": "Berechne die Bogenlänge eines Kreisausschnitts mit $r = 6\\,\\text{cm}$ und Mittelpunktswinkel $\\alpha = 120^\\circ$. Runde auf eine Dezimalstelle. (Antwort in cm.)",
      "eingaben": [
        { "label": "Bogenlänge in cm", "antwort": 12.6, "toleranz": 0.1 }
      ],
      "tipps": [
        "Formel: $b = \\frac{\\alpha}{360^\\circ} \\cdot 2\\pi r$.",
        "Anteil: $\\frac{120}{360} = \\frac{1}{3}$.",
        "$b = \\frac{1}{3} \\cdot 2\\pi \\cdot 6 = 4\\pi \\approx 12{,}6\\,\\text{cm}$."
      ],
      "loesungsweg": "$b = \\frac{120^\\circ}{360^\\circ} \\cdot 2\\pi \\cdot 6 = \\frac{1}{3} \\cdot 12\\pi = 4\\pi \\approx 12{,}6\\,\\text{cm}$.",
      "kc": ["Raum und Form: Kreisbogen"]
    },
    {
      "id": "ma-09-kb-105",
      "typ": "numerisch",
      "zweig": ["gym", "rs"],
      "niveau": 3,
      "afb": 3,
      "ergaenzung": "lernbuero",
      "frage": "Ein Kreisring hat Außenradius $R = 8\\,\\text{cm}$ und Innenradius $r = 5\\,\\text{cm}$. Berechne seine Fläche. Runde auf eine Dezimalstelle. (Antwort in cm².)",
      "eingaben": [
        { "label": "Fläche in cm²", "antwort": 122.5, "toleranz": 0.2 }
      ],
      "tipps": [
        "Kreisring: große Kreisfläche minus kleine Kreisfläche.",
        "$A = \\pi R^2 - \\pi r^2 = \\pi(R^2 - r^2)$.",
        "$A = \\pi(64 - 25) = 39\\pi \\approx 122{,}5\\,\\text{cm}^2$."
      ],
      "loesungsweg": "$A = \\pi(R^2 - r^2) = \\pi(8^2 - 5^2) = \\pi(64 - 25) = 39\\pi \\approx 122{,}5\\,\\text{cm}^2$.",
      "kc": ["Raum und Form: zusammengesetzte Flächen"]
    }
  ]
}
