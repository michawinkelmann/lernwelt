        { "text": "$-9$", "richtig": false, "erklaerung": "Negative Exponenten erzeugen keine negativen Zahlen, sondern Kehrwerte." },
        { "text": "$\\frac{1}{9}$", "richtig": true, "erklaerung": "$3^{-2} = \\frac{1}{3^2} = \\frac{1}{9}$." },
        { "text": "$-\\frac{1}{9}$", "richtig": false, "erklaerung": "Die Basis $3$ ist positiv, also ist auch $3^{-2}$ positiv." },
        { "text": "$\\frac{1}{6}$", "richtig": false, "erklaerung": "$3^{-2}$ bedeutet Kehrwert von $3^2 = 9$, nicht von $3 \\cdot 2 = 6$." }
      ],
      "tipps": [
        "Das Potenzgesetz fuer negative Exponenten: $a^{-n} = \\frac{1}{a^n}$.",
        "Berechne zuerst $3^2$, dann bilde den Kehrwert.",
        "$3^2 = 9$, also $3^{-2} = \\frac{1}{9}$."
      ],
      "loesungsweg": "Nach dem Potenzgesetz gilt $3^{-2} = \\frac{1}{3^2} = \\frac{1}{9}$.",
      "kc": ["Zahlen und Operationen"],
      "ergaenzung": "lernbuero"
    },
